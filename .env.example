# Copy this to .env.local and fill in your values
# Get each key from the service listed in comments

# ============================================================
# ANTHROPIC — console.anthropic.com
# ============================================================
ANTHROPIC_API_KEY=

# ============================================================
# SUPABASE — app.supabase.com → your project → settings → API
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# SHOPIFY — partners.shopify.com → create app
# ============================================================
SHOPIFY_API_KEY=
NEXT_PUBLIC_SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================
# META — developers.facebook.com → create app → marketing API
# ============================================================
META_APP_ID=
NEXT_PUBLIC_META_APP_ID=
META_APP_SECRET=

# ============================================================
# GOOGLE ADS — ads.google.com → tools → API centre
# ============================================================
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================================
# RESEND — resend.com → API keys
# ============================================================
RESEND_API_KEY=
# Optional: override the sender address (must be a verified domain in Resend)
EMAIL_FROM=Brain <briefs@updates.brainapp.in>

# ============================================================
# RAZORPAY — dashboard.razorpay.com → settings → API keys
# ============================================================
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Create plans in Razorpay dashboard → Products → Plans
RAZORPAY_PLAN_ID_STARTER=
RAZORPAY_PLAN_ID_GROWTH=
RAZORPAY_PLAN_ID_SCALE=

# ============================================================
# UPSTASH REDIS — upstash.com → create database → REST API
# ============================================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============================================================
# INTERNAL
# ============================================================
# Generate with: openssl rand -hex 32
CRON_SECRET=
